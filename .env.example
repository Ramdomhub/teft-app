# TEFT App - Environment Variables
# Kopiere diese Datei zu .env.local und fülle die Werte aus.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Solana RPC (empfohlen: Helius für bessere Rate Limits)
# Beispiel: https://mainnet.helius-rpc.com/?api-key=DEIN_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=

# Helius Webhook Secret (optional, für Production empfohlen)
HELIUS_WEBHOOK_SECRET=
